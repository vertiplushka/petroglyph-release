# ── MySQL (Docker) ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=petroglyph
MYSQL_USER=petroglyph
MYSQL_PASSWORD=change_me_db

# ── NestJS backend ───────────────────────────────────────────────────────────
# DATABASE_URL — только для локального запуска без Docker (npm run dev в backend/)
DATABASE_URL=mysql://petroglyph:change_me_db@localhost:3306/petroglyph
PORT=4000
JWT_SECRET=change_me_64_char_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin
INTERNAL_SECRET=change_me_random_64_chars

# ── Next.js frontend (server-side, никогда не PUBLIC_) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Внутренний адрес бэкенда для чтения мест из БД (в Docker — http://backend:4000)
BACKEND_INTERNAL_URL=http://localhost:4000

# AI API базовый URL - для продакшнения может быть другим сервером
# Пример: https://api.example.com/v1
ANTHROPIC_API_BASE_URL=https://altaiguide.ru/v1

# Модель Claude для AI-гида. Варианты (от дешевле к умнее):
#   claude-haiku-4-5     — быстрый и дешёвый, хорошо для демо/ВКР
#   claude-sonnet-4-6    — баланс качества и цены
#   claude-opus-4-6      — высокое качество
#   claude-opus-4-7      — наиболее мощный
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Certbot (только продакшн) ─────────────────────────────────────────────────
CERTBOT_EMAIL=your@email.com
